# ============================================
# Application Configuration
# ============================================
VITE_APP_ID=family-recipes
VITE_APP_NAME=Family Recipes
VITE_APP_DESCRIPTION=Family Recipes for sharing recipes and shopping lists with your family.

# ============================================
# Internationalization (i18n)
# ============================================
VITE_DEFAULT_LOCALE=en
VITE_FALLBACK_LOCALE=en

# ============================================
# Contact Information
# ============================================
VITE_COMPANY_NAME=DEV Made IT
VITE_COMPANY_WEBSITE=https://dev-made.it
VITE_CONTACT_EMAIL=contact@dev-made.it

# ============================================
# Backend Configuration
# ============================================
VITE_ENABLE_BACKEND=true
# Dev: `/api` (Vite proxy). Production deploy: full URL, e.g. https://api.family-recipes.dev-made.it/api
VITE_API_BASE_URL=/api
VITE_API_PROXY_URL=http://localhost:8000

# ============================================
# Development Server
# ============================================
VITE_PORT=5176

# ============================================
# Google reCAPTCHA
# ============================================
# Get your site key from: https://www.google.com/recaptcha/admin
VITE_GOOGLE_RECAPTCHA_SITE_KEY=

# ============================================
# OAuth Configuration
# ============================================
# Google OAuth
# Get your client ID from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Facebook OAuth
# Get your client ID from: https://developers.facebook.com/apps
VITE_FACEBOOK_OAUTH_CLIENT_ID=

# ============================================
# Feature Flags
# ============================================
VITE_ENABLE_IMAGE_SEARCH=false
VITE_ENABLE_AI=false
VITE_ENABLE_INLINE_EDITING=false

# ============================================
# Storage Configuration
# ============================================
# Maximum file size for regular users (in bytes, default: 20 MB)
VITE_MAX_FILE_SIZE=20971520
# Maximum file size for administrators (in bytes, default: 50 MB)
VITE_MAX_FILE_SIZE_ADMIN=52428800

# ============================================
# Sentry Error Tracking (Frontend)
# ============================================
# Get your DSN from your Sentry project settings
# Format: https://<key>@<org>.ingest.sentry.io/<project>
# Access: https://<org>.sentry.io/settings/projects/<project>/keys/
# Sentry is enabled automatically when VITE_SENTRY_DSN is set
VITE_SENTRY_DSN=
# Environment name (defaults to Vite MODE: development, production, etc.)
VITE_SENTRY_ENVIRONMENT=
# Performance monitoring sample rate (0.0 to 1.0, default: 1.0 = 100%)
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0
# Session replay sample rate (0.0 to 1.0, default: 0.1 = 10%)
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
# Session replay on error sample rate (0.0 to 1.0, default: 1.0 = 100%)
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# ============================================
# Sentry Source Maps Upload (Build-time only)
# ============================================
# These variables are only used during production builds to upload source maps
# Organization slug (found in your organization URL: https://<org>.sentry.io/)
# Access: https://<org>.sentry.io/settings/
SENTRY_ORG=
# Project slug (found in your project settings)
# Access: https://<org>.sentry.io/settings/projects/<project>/
SENTRY_PROJECT=
# Create an auth token at: https://<org>.sentry.io/settings/auth-tokens/
# Required permissions: project:releases, org:read
SENTRY_AUTH_TOKEN=
