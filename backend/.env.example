# =============================================================================
# Family Recipes Backend - Environment Variables Configuration
# =============================================================================
# Copy this file to .env and update the values according to your environment.
# All variables are optional and have defaults, but some are required for
# production use (marked with [REQUIRED]).
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=backend
APP_DISPLAY_NAME=Family Recipes
APP_VERSION=0.1.2
DEBUG=false
# ENVIRONMENT options: local, development, test, production
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=true
# CORS_ORIGINS: JSON array format, e.g., '["http://localhost:3000","http://localhost:5173"]'
CORS_ORIGINS=["http://localhost:3000"]
CORS_CREDENTIALS=true
# CORS_METHODS: JSON array format, e.g., '["GET","POST","PUT","DELETE"]' or '["*"]'
CORS_METHODS=["*"]
# CORS_HEADERS: JSON array format, e.g., '["*"]'
CORS_HEADERS=["*"]
# ALLOWED_HOSTS: JSON array format, e.g., '["localhost","127.0.0.1","api.example.com"]'
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite (development):
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# PostgreSQL (production):
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/familyrecipes
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# PostgreSQL connection (for Docker Compose)
POSTGRES_DB=backend
POSTGRES_USER=backend
POSTGRES_PASSWORD=changeme
DB_FORWARD_PORT=5432

# Redis connection (for Docker Compose)
REDIS_PASSWORD=changeme
REDIS_FORWARD_PORT=6379

# -----------------------------------------------------------------------------
# Security & Authentication [REQUIRED for production]
# -----------------------------------------------------------------------------
# [REQUIRED] Generate a secure random string (min 32 characters)
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-min-32-chars!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRES_HOURS=1
EMAIL_VERIFICATION_TOKEN_EXPIRES_HOURS=24

# Super Admin Configuration
# Email address of the super admin user (owner) - cannot be deleted or demoted
SUPERADMIN_EMAIL=
# Protected user email - this user cannot be deleted
PROTECTED_USER_EMAIL=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_DEFAULT_PER_HOUR=1000
AUTH_REGISTER_RATE_LIMIT=5/minute
AUTH_LOGIN_RATE_LIMIT=10/minute
AUTH_REFRESH_RATE_LIMIT=20/minute
AUTH_PASSWORD_CHANGE_RATE_LIMIT=3/minute

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(name)s | %(levelname)s | %(message)s
# LOG_FILE=./logs/app.log  # Optional: log to file

# -----------------------------------------------------------------------------
# Sentry Error Monitoring (Optional)
# -----------------------------------------------------------------------------
SENTRY_ENABLED=false
# SENTRY_DSN: Get from https://sentry.io/settings/projects/
SENTRY_DSN=
# SENTRY_ENVIRONMENT options: development, staging, production
SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE: Performance monitoring sample rate (0.0-1.0)
SENTRY_TRACES_SAMPLE_RATE=1.0
# SENTRY_PROFILES_SAMPLE_RATE: Profiling sample rate (0.0-1.0)
SENTRY_PROFILES_SAMPLE_RATE=1.0
# SENTRY_RELEASE: Release version (e.g., git commit SHA or version number)
# SENTRY_RELEASE=

# -----------------------------------------------------------------------------
# Google reCAPTCHA v3 (Optional - for additional security)
# -----------------------------------------------------------------------------
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_MIN_SCORE=0.5
# RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify

# -----------------------------------------------------------------------------
# OAuth Authentication (Google)
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# -----------------------------------------------------------------------------
# OAuth Authentication (Facebook)
# -----------------------------------------------------------------------------
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=

# -----------------------------------------------------------------------------
# OAuth Login — GitHub (callback: /auth/github)
# -----------------------------------------------------------------------------
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://family-recipes.dev-made.it/auth/github

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
EMAIL_ENABLED=true
# EMAIL_ADAPTER options: file (development), smtp (production)
EMAIL_ADAPTER=file
EMAIL_FILE_PATH=./emails
EMAIL_ENABLE_AUDIT=true

# SMTP Configuration (for production)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true
# EMAIL_ENABLE_RETRY=false
# EMAIL_MAX_RETRIES=5

# -----------------------------------------------------------------------------
# File Storage Configuration
# -----------------------------------------------------------------------------
# STORAGE_TYPE options: local, s3
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
# Base URL for serving uploaded files (for absolute URLs)
# Examples:
#   Development: STORAGE_BASE_URL=http://localhost:8000
#   Production: STORAGE_BASE_URL=https://api.family-recipes.com
STORAGE_BASE_URL=http://localhost:8000

# S3/MinIO Storage Configuration (when STORAGE_TYPE=s3)
STORAGE_S3_BUCKET=uploads
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin123
STORAGE_S3_REGION=us-east-1
# For MinIO (S3-compatible): STORAGE_S3_ENDPOINT_URL=http://minio:9000
# Public S3 endpoint URL for generating accessible URLs (e.g., http://localhost:9000 for MinIO)
# If not set, uses STORAGE_S3_ENDPOINT_URL
STORAGE_S3_PUBLIC_ENDPOINT_URL=

# For AWS S3: leave STORAGE_S3_ENDPOINT_URL empty or unset
STORAGE_S3_ENDPOINT_URL=http://minio:9000

# Storage Limits & Processing
# STORAGE_MAX_FILE_SIZE in bytes (default: 10MB = 10485760)
STORAGE_MAX_FILE_SIZE=10485760
# STORAGE_MAX_FILE_SIZE_ADMIN in bytes (default: 50MB = 52428800)
# Note: Limits are now managed via feature_limits table, this is fallback only
STORAGE_MAX_FILE_SIZE_ADMIN=52428800

STORAGE_MAX_FILES_PER_ITEM=10
# STORAGE_ALLOWED_MIME_TYPES: JSON array format
STORAGE_ALLOWED_MIME_TYPES=["image/jpeg","image/png","image/webp","image/gif"]
STORAGE_ENABLE_PROCESSING=true
STORAGE_MAX_WIDTH=1920
STORAGE_MAX_HEIGHT=1920
STORAGE_JPEG_QUALITY=85
STORAGE_CONVERT_TO_WEBP=false

# -----------------------------------------------------------------------------
# MinIO Configuration (for docker-compose.dev.yml)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Ops Monitor — Health Details Endpoint (GET /api/health/details)
# -----------------------------------------------------------------------------
# [REQUIRED to enable] Bearer token required to call /api/health/details.
# Without it, the endpoint always returns 401 (fails closed).
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
HEALTH_DETAILS_TOKEN=

# -----------------------------------------------------------------------------
# Docker Compose Variables (optional overrides)
# -----------------------------------------------------------------------------
PROJECT_NAME=backend
APP_PORT=8000

# -----------------------------------------------------------------------------
# AI Configuration (OpenRouter Integration)
# -----------------------------------------------------------------------------
# AI features are currently restricted to admin users only
AI_ENABLED=true

# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AI Token Encryption
# [REQUIRED if AI_ENABLED=true] Generate a Fernet key using:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AI_TOKEN_ENCRYPTION_KEY=

# AI Cache Configuration
AI_CACHE_ENABLED=true
# Cache TTL in days
AI_CACHE_TTL_CLASSIFY=7
AI_CACHE_TTL_EMBED=30

# AI Limits (for system token usage - future feature)
# AI_SYSTEM_TOKEN_MONTHLY_LIMIT=1000000
# AI_SYSTEM_TOKEN_COST_LIMIT=50.00

# AI Monitoring (optional)
# AI_HEALTH_CHECK_INTERVAL=300

# -----------------------------------------------------------------------------
# Stripe Billing Configuration
# -----------------------------------------------------------------------------
STRIPE_ENABLED=false
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (created in Stripe Dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_PRO_PLUS_MONTHLY_PRICE_ID=
STRIPE_PRO_PLUS_ANNUAL_PRICE_ID=
